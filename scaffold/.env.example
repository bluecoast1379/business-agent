# ============================================================
# agent-gateway-scaffold 环境变量样例
# 复制为 .env 后按需填写：cp .env.example .env
# .env 不会被自动加载；由 shell / process manager / secret manager 注入。
# 本文件只含占位值，不含真实密钥或内部地址。
# ============================================================

# ---- Runtime profile ----
# development：允许 memory/local，适合本地 mock。
# production：强制 principals + durable state + durable scheduler。
RUNTIME_PROFILE=development

# ---- LLM provider（必填）----
# mock                = 确定性离线 provider（开发、测试、eval）
# anthropic           = Anthropic Messages API（需要 LLM_API_KEY）
# openai-compatible   = /v1/chat/completions 兼容 API
LLM_PROVIDER=mock
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=claude-sonnet-4-6
# LLM_COMPLEX_MODEL=claude-sonnet-4-6
# production 必须为 LLM_MODEL/LLM_COMPLEX_MODEL 逐个提供精确单价，不使用通用默认价。
# LLM_PRICE_TABLE_JSON={"claude-sonnet-4-6":{"inputPerMTok":3,"outputPerMTok":15}}
# LLM_MAX_TURNS=8
# LLM_MAX_TOKENS=1024

# ---- Authentication / RBAC ----
# production 必填。必须是一行 JSON 数组；每个 token 至少 12 字符。
# roles：caller|operator|admin|service|auditor；scopes 按最小权限授予。
# AUTH_PRINCIPALS_JSON=[{"token":"<generated-token-at-least-12-chars>","principal":{"subjectId":"local-operator","tenantId":null,"roles":["operator"],"scopes":["chat:write","status:read","confirmations:read","confirmations:write","jobs:run","dashboard:read","runs:read","costs:read","evals:read","approvals:read","audit:read","system:read"]}}]

# 旧版单 token 迁移入口；development 可单独使用，production 仍要求
# AUTH_PRINCIPALS_JSON。配置后映射为 legacy admin，不建议新部署使用。
GATEWAY_AUTH_TOKEN=

# ---- State / scheduler ----
# memory 只用于 development；production 必须 file 或注入外部 driver。
STATE_ADAPTER=memory
# STATE_FILE_PATH=./local/state.json
# local 只用于 development；production 必须 durable。
SCHEDULER_ADAPTER=local

# ---- Telemetry / dashboard ----
# 隐私默认：关闭时不发 exporter 请求。启用时 endpoint 必填。
TELEMETRY_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://collector.example
# dashboard 只读；仍需 operator/admin/auditor + dashboard/page scopes。
DASHBOARD_ENABLED=true

# ---- Tenant quotas ----
# QUOTA_REQUESTS_PER_MINUTE=60
# QUOTA_CONCURRENCY=8
# QUOTA_TENANT_OVERRIDES_JSON={"tenant-a":{"requestsPerMinute":120,"concurrency":16}}

# ---- Idempotency evidence ----
# 持久层默认只保存摘要/墓碑；完整 crash evidence 仅在调用方显式启用时
# 最多短时保留。容量耗尽会 fail-closed，需有权 operator 对账。
# IDEMPOTENCY_MAX_RECORDS=10000
# IDEMPOTENCY_RESULT_RETENTION_SECONDS=300

# ---- Append-only audit evidence ----
# 达到上限后绝不静默删除证据；先导出校验并归档整个 state，再轮换到新的 state 文件。
# AUDIT_MAX_RECORDS=10000

# ---- HTTP ----
# PORT=3000
# HOST=127.0.0.1
# production 对非 loopback HOST 必须显式声明前置可信 HTTPS ingress。
# Node listener 只能绑定该 ingress 可达的私网地址，不能直接暴露公网明文 HTTP。
# TLS_TERMINATED_BY_TRUSTED_PROXY=false

# ---- Budget guardrails ----
# BUDGET_MAX_USD_PER_REQUEST=0.5
# BUDGET_MONTHLY_USD=50
# 预算预留 lease；进程崩溃后到期会按未知结果保守计入上限并释放 lease。
# BUDGET_RESERVATION_TTL_SECONDS=7200

# ---- Session ----
# SESSION_TTL_MINUTES=30

# ---- Business backend（demo toolpack 不需要）----
# BACKEND_URL=
# BACKEND_API_KEY=

# ---- Inbound webhook（可选）----
# 设置 WEBHOOK_SECRET 后启用 POST /webhook。请求需带 x-timestamp（Unix 秒）
# 与 x-signature-256：sha256=HMAC_SHA256(secret, "<timestamp>.<raw-body>")。
# secret 至少 16 字符；production 还必须显式提供 WEBHOOK_PRINCIPAL_JSON。
# WEBHOOK_SECRET=
# WEBHOOK_INTEGRATION_ID=default
# WEBHOOK_PRINCIPAL_JSON={"subjectId":"webhook:orders","tenantId":"tenant-a","roles":["caller"],"scopes":["chat:write"],"authType":"webhook-hmac"}
# WEBHOOK_REPLAY_TTL_SECONDS=600
# WEBHOOK_REPLAY_MAX_RECORDS=10000

# ---- Outbound notification / patrol ----
# NOTIFY_WEBHOOK_URL=
# PATROL_OVERDUE_DAYS=7
# PATROL_MIN_ONTIME_RATE=0.9

# ---- Production minimum（示例，取消注释并通过安全系统注入真实值）----
# RUNTIME_PROFILE=production
# AUTH_PRINCIPALS_JSON=[...]
# STATE_ADAPTER=file
# STATE_FILE_PATH=/controlled-volume/business-agent/state.json
# SCHEDULER_ADAPTER=durable
# LLM_PRICE_TABLE_JSON={"<approved-model-id>":{"inputPerMTok":3,"outputPerMTok":15}}
