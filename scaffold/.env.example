# ============================================================
# agent-gateway-scaffold 环境变量样例
# 复制为 .env 后按需填写:cp .env.example .env
# 本文件只含键名与说明,不含任何真实密钥 / 内部地址。
# ============================================================

# ---- LLM Provider(必填) ----
# mock      = 本地确定性假模型,零成本跑通全链路(推荐首次体验)
# anthropic = 真实 Anthropic Messages API(需要 LLM_API_KEY)
LLM_PROVIDER=mock

# anthropic 时必填。绝不要把真实 key 提交进版本库(.env 已被 .gitignore 忽略)。
# LLM_API_KEY=

# 可选:API 基址(默认公开端点 https://api.anthropic.com,一般无需修改)
# LLM_BASE_URL=

# 可选:默认模型 / 复杂任务模型(公开模型 id)
# LLM_MODEL=claude-sonnet-4-6
# LLM_COMPLEX_MODEL=claude-sonnet-4-6

# 可选:单价表覆盖(JSON,单位 USD / 百万 token),用于成本折算
# LLM_PRICE_TABLE_JSON={"claude-sonnet-4-6":{"inputPerMTok":3,"outputPerMTok":15}}

# 可选:单次会话最大轮数 / 单轮最大输出 token
# LLM_MAX_TURNS=8
# LLM_MAX_TOKENS=1024

# ---- 网关鉴权(必填) ----
# 除 GET /health 外所有 HTTP 端点都要求 Authorization: Bearer <此值>。
# 生成建议:openssl rand -hex 24
GATEWAY_AUTH_TOKEN=

# ---- HTTP 服务 ----
# PORT=3000
# HOST=127.0.0.1

# ---- 预算护栏(双层) ----
# 单次请求上限(USD):超出后中断 tool 循环,返回已得内容+提示
# BUDGET_MAX_USD_PER_REQUEST=0.5
# 月度总额上限(USD):超出后拒绝新会话、巡检任务跳过
# BUDGET_MONTHLY_USD=50

# ---- 会话 ----
# SESSION_TTL_MINUTES=30

# ---- 真实业务后端(可选;demo toolpack 不需要) ----
# 接真实后端时由你的 toolpack 读取;scaffold 不内置任何后端地址
# BACKEND_URL=
# BACKEND_API_KEY=

# ---- 入站 webhook 渠道(可选) ----
# 设置后启用 POST /webhook。入站请求需带 x-timestamp(unix 秒)与
# x-signature-256: sha256=HMAC_SHA256(secret, "<timestamp>.<原始 body>")
# 时间戳偏差超过 300 秒拒绝(防重放)
# WEBHOOK_SECRET=

# ---- 出站通知渠道(可选) ----
# 巡检报告推送地址(任意接受 JSON POST 的通知渠道);不设则打印到控制台
# NOTIFY_WEBHOOK_URL=

# ---- 巡检阈值(可覆盖) ----
# PATROL_OVERDUE_DAYS=7
# PATROL_MIN_ONTIME_RATE=0.9
