{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://business-agent.local/schemas/agent.schema.json",
  "title": "Business Agent Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "model", "tools"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "model": { "type": "string", "minLength": 1 },
    "systemPromptRef": { "type": "string" },
    "tools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "maxTurns": { "type": "integer", "minimum": 1 },
    "maxTokens": { "type": "integer", "minimum": 1 }
  }
}
